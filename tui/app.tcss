/* ══════════════════════════════════════════════════════
   Claude Agent Runner — Dracula theme
   All base colors flow from the registered Theme object.
   This file handles structure + Dracula-specific overrides.
   ══════════════════════════════════════════════════════ */

/* ── App shell ─────────────────────────────────────────── */
Screen {
    layout: horizontal;
}

Header {
    text-style: bold;
}

/* ── Panels ────────────────────────────────────────────── */
#agents-panel {
    width: 32;
    layout: vertical;
    border-right: solid $boost;
}

#runs-panel {
    width: 1fr;
    layout: vertical;
    border-right: solid $boost;
}

#stream-panel {
    width: 2fr;
    layout: vertical;
    background: #0d0e13;
}

/* ── Panel title bars ─────────────────────────────────── */
.panel-title {
    background: $panel;
    text-style: bold;
    padding: 0 1;
    height: 1;
    width: 100%;
    border-bottom: solid $boost;
}

#agents-title { color: $primary; }
#runs-title   { color: $secondary; }
#stream-title { color: $accent; }

/* ── Content widgets ──────────────────────────────────── */
#stream-log {
    height: 1fr;
    background: #0d0e13;
    color: $foreground;
}

/* ── Toolbars ─────────────────────────────────────────── */
.toolbar {
    height: 3;
    padding: 0 1;
    background: $panel;
    align: left middle;
    border-top: solid $boost;
}

/* ── Buttons ──────────────────────────────────────────── */
Button {
    height: 1;
    min-width: 10;
    margin-right: 1;
    border: none;
}

/* ── DataTable ────────────────────────────────────────── */
DataTable > .datatable--header {
    background: $panel;
    color: $primary;
    text-style: bold;
}

DataTable > .datatable--even-row { background: #1e1f29; }

/* ── NewAgentScreen modal ─────────────────────────────── */
NewAgentScreen {
    align: center middle;
}

#dialog {
    background: $surface;
    border: round $primary;
    padding: 1 2;
    width: 70;
    height: auto;
    max-height: 90%;
}

#dialog-title      { text-style: bold; margin-bottom: 1; color: $primary; }
#agent-prompt      { height: 8; margin-bottom: 1; }
.field-label       { color: #6272a4; margin-top: 1; }
#tools-row         { height: auto; }
#bottom-row        { margin-top: 1; height: 3; }
#turns-input       { width: 6; }
#perm-select       { width: 20; }
.dialog-buttons    { align: right middle; }

/* ── ScanAgentsScreen modal ───────────────────────────── */
ScanAgentsScreen {
    align: center middle;
}

#scan-dialog {
    background: $surface;
    border: round $primary;
    padding: 1 2;
    width: 80;
    height: auto;
    max-height: 90%;
}

#scan-title        { text-style: bold; color: $primary; margin-bottom: 1; }
#scan-dir-label    { color: #6272a4; margin-bottom: 1; }
#scan-list         { height: auto; max-height: 30; overflow-y: auto; }
.scan-item         { border-bottom: solid $boost; padding: 0 0 1 0; margin-bottom: 1; }
.scan-item-name    { text-style: bold; color: $foreground; }
.scan-item-file    { color: #6272a4; }
.scan-item-prompt  { color: $foreground; }
#scan-buttons      { margin-top: 1; align: right middle; }
#scan-empty        { color: #6272a4; padding: 1 0; }
